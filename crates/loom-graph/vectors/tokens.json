{
  "description": "Encoding-neutral vectors for token-graph validation and the §7 resolution oracle",
  "vectors": [
    {
      "id": "tokens-positive-resolution",
      "description": "A component token resolving through the semantic tier to a primitive — coherent",
      "fixture": {
        "type": "TokenGraph",
        "tokens": [
          { "id": "color.blue.500", "tier": "primitive", "value": "#2563eb" },
          { "id": "surface.interactive", "tier": "semantic", "binds": "color.blue.500" },
          { "id": "button.background", "tier": "component", "binds": "surface.interactive", "component": "Ref.Button" }
        ]
      },
      "expected": { "shacl_passes": true, "resolves": true }
    },
    {
      "id": "tokens-negative-cycle",
      "description": "Two semantic tokens binding each other — resolution cycle, incoherent",
      "fixture": {
        "type": "TokenGraph",
        "tokens": [
          { "id": "surface.a", "tier": "semantic", "binds": "surface.b" },
          { "id": "surface.b", "tier": "semantic", "binds": "surface.a" },
          { "id": "button.background", "tier": "component", "binds": "surface.a", "component": "Ref.Button" }
        ]
      },
      "expected": { "shacl_passes": true, "resolves": false }
    },
    {
      "id": "tokens-negative-dangling",
      "description": "A component token binding a token that does not exist — dangling reference",
      "fixture": {
        "type": "TokenGraph",
        "tokens": [
          { "id": "button.background", "tier": "component", "binds": "surface.ghost", "component": "Ref.Button" }
        ]
      },
      "expected": { "shacl_passes": true, "resolves": false }
    },
    {
      "id": "tokens-negative-semantic-without-binding",
      "description": "A semantic token with no binds edge — rejected by the shape (dual encoding of loom-spec §2)",
      "fixture": {
        "type": "TokenGraph",
        "tokens": [
          { "id": "color.blue.500", "tier": "primitive", "value": "#2563eb" },
          { "id": "surface.interactive", "tier": "semantic" }
        ]
      },
      "expected": { "shacl_passes": false, "resolves": true }
    },
    {
      "id": "tokens-negative-component-skips-semantic-tier",
      "description": "A component token binding a primitive directly — must resolve through the semantic tier",
      "fixture": {
        "type": "TokenGraph",
        "tokens": [
          { "id": "color.blue.500", "tier": "primitive", "value": "#2563eb" },
          { "id": "button.background", "tier": "component", "binds": "color.blue.500", "component": "Ref.Button" }
        ]
      },
      "expected": { "shacl_passes": true, "resolves": false }
    }
  ]
}
