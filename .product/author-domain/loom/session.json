          },
          {
            "projection": "rm-catalog-inventory",
            "state": "present",
            "meaning": "Every component in the catalog is listed with its states and declared events — pick one to drive it."
          },
          {
            "projection": "rm-catalog-inventory",
            "state": "empty",
            "meaning": "No bundles are loaded; the gallery has nothing to show until core's reference bundles are loaded."
          },
          {
            "projection": "rm-catalog-inventory",
            "state": "failed",
            "meaning": "The store could not be queried; the gallery cannot build its page list."
