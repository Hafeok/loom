        "id": "sys-loom-cli",
        "label": "loom-cli",
        "kind": "cli",
        "purpose": "The `loom` binary — the product-cli-facing surface: load and validate bundles, ingest palettes, reify intents, emit reports, derive and check bindings, and answer the §8 queries over the embedded Oxigraph store.",
        "references_domain": [
          "ctx-catalog",
          "ctx-ingestion",
          "ctx-reification",
          "ctx-binding"
        ]
      },
      {
        "id": "sys-loom-runtime",
        "label": "loom-runtime",
        "kind": "service",
        "purpose": "The headless machine runtime — one compiled Rust core (wasm via wasm-bindgen for loom-web; static libraries via UniFFI for loom-ios/loom-android) exposing exactly the mode-contract surfaces: dispatch(event), the descriptor observable, mount/unmount. Modes are this runtime plus a thin platform shim; adapters package it per framework.",
        "references_domain": [
          "ctx-catalog",
          "ctx-runtime",
          "ctx-binding"
        ]
      },
      {
        "id": "sys-gallery",
        "label": "Conformance Gallery",
        "kind": "application",
        "purpose": "The per-adapter runnable gallery (loom-web-react-gallery first): pages generated from core's composition-graphs and mode-contracts, rendering core's reference data through the adapter and the FixtureDriver — the visual/interactive counterpart to the oracles, and the acceptance test for the mode-contract itself.",
        "root": "ar-gallery",
        "references_domain": [
          "ctx-catalog",
          "ctx-runtime",
          "ctx-binding"
        ]
      }
    ],
